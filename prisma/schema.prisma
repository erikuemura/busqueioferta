generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Offer {
  id              String      @id @default(cuid())
  title           String
  description     String?
  imageUrl        String
  originalPrice   Float
  currentPrice    Float
  discountPercent Float
  affiliateUrl    String
  marketplace     Marketplace
  category        Category
  status          OfferStatus @default(ACTIVE)
  featured        Boolean     @default(false)
  score           Float       @default(0) // relevância calculada no sync
  expiresAt       DateTime?
  stockStatus     StockStatus @default(IN_STOCK)
  rating          Float?
  reviewCount     Int?
  externalId      String? // ID do produto no marketplace
  externalSku     String?
  notFoundCount   Int         @default(0) // verificações consecutivas sem encontrar
  clicks          Int         @default(0)
  shares          Int         @default(0)
  publishedAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  socialPosts SocialPost[]
  tags        Tag[]
  events      ClickEvent[]

  @@unique([marketplace, externalId])
  @@index([status, category])
  @@index([discountPercent])
  @@index([createdAt])
}

// Evento datado de clique/compartilhamento — base do analytics por janela de tempo.
model ClickEvent {
  id          String    @id @default(cuid())
  offerId     String?
  offer       Offer?    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  couponId    String?
  type        EventType @default(CLICK)
  referer     String?
  source      String? // host de origem (ex.: instagram.com, t.co)
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  country     String?
  device      String? // mobile | desktop
  createdAt   DateTime  @default(now())

  @@index([createdAt])
  @@index([offerId, type])
  @@index([utmSource])
}

enum EventType {
  CLICK
  SHARE
  VIEW
}

// Cupons de desconto por marketplace (SEO programático /cupons/[marketplace]).
model Coupon {
  id           String      @id @default(cuid())
  code         String
  title        String
  description  String?
  marketplace  Marketplace
  category     Category?
  discountText String? // "10% OFF", "R$ 50 OFF", "Frete grátis"
  affiliateUrl String
  verified     Boolean     @default(false)
  featured     Boolean     @default(false)
  expiresAt    DateTime?
  clicks       Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([marketplace])
  @@index([category])
}

// Campanhas de tráfego para atribuição de cliques/receita de afiliados.
model Campaign {
  id        String   @id @default(cuid())
  name      String   @unique
  utmSource String?
  utmMedium String?
  channel   String? // instagram | telegram | whatsapp | seo | ...
  createdAt DateTime @default(now())
}

enum Marketplace {
  MERCADO_LIVRE
  AMAZON
  MAGAZINE_LUIZA
  SHOPEE
  AMERICANAS
  KABUM
  CASAS_BAHIA
  PONTO
  MANUAL
}

enum Category {
  ELETRONICOS
  GAMES
  VESTUARIO
  CALCADOS
  PERFUMES_COSMETICOS
  ELETRODOMESTICOS
  CASA_DECORACAO
  LIVROS
  ESPORTES
  INFANTIL
  ALIMENTOS
  OUTROS
}

enum OfferStatus {
  ACTIVE
  EXPIRED
  OUT_OF_STOCK
  ARCHIVED
  DRAFT
}

enum StockStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
}

model SocialPost {
  id          String         @id @default(cuid())
  offerId     String
  offer       Offer          @relation(fields: [offerId], references: [id], onDelete: Cascade)
  platform    SocialPlatform
  status      PostStatus     @default(PENDING)
  imageUrl    String?
  caption     String?
  scheduledAt DateTime?
  publishedAt DateTime?
  externalId  String?
  error       String?
  createdAt   DateTime       @default(now())

  @@index([status, platform])
}

enum SocialPlatform {
  WHATSAPP
  INSTAGRAM
  TIKTOK
  TELEGRAM
  FACEBOOK
  PINTEREST
}

enum PostStatus {
  PENDING
  SCHEDULED
  PUBLISHED
  FAILED
}

model Tag {
  id     String  @id @default(cuid())
  name   String  @unique
  offers Offer[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(EDITOR)
  // Perfil do cliente (role CUSTOMER)
  phone        String?
  interests    Category[]
  wantsWhatsapp Boolean   @default(true)
  wantsEmail    Boolean   @default(true)
  lastDigestAt  DateTime?
  createdAt DateTime @default(now())

  directMessages    DirectMessage[]
  pushSubscriptions PushSubscription[]
}

// Inscrição de notificação push (Web Push). Pode ou não estar ligada a um cliente.
model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([userId])
}

// Registro de envio direto (WhatsApp/e-mail) a um cliente — dedup + status.
model DirectMessage {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  offerId   String?
  channel   MessageChannel @default(WHATSAPP)
  status    DispatchStatus @default(SENT)
  error     String?
  createdAt DateTime       @default(now())

  @@unique([userId, offerId, channel])
  @@index([createdAt])
}

enum MessageChannel {
  WHATSAPP
  EMAIL
}

enum DispatchStatus {
  SENT
  FAILED
  PENDING
}

enum Role {
  ADMIN
  EDITOR
  CUSTOMER
}

model AlertSubscription {
  id         String     @id @default(cuid())
  email      String
  categories Category[]
  active     Boolean    @default(true)
  lastSentAt DateTime?
  createdAt  DateTime   @default(now())

  @@unique([email])
}

model Settings {
  key   String @id
  value String
}
