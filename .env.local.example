# ==========================================================================
# busqueioferta — variáveis de ambiente
# Copie este arquivo para .env.local e preencha. Para rodar o MVP com dados
# de seed você só precisa de DATABASE_URL + NEXTAUTH_SECRET.
# ==========================================================================

# ----- Database (PostgreSQL) -----
# Local via docker-compose (ver docker-compose.yml):
DATABASE_URL="postgresql://busqueioferta:busqueioferta@localhost:5432/busqueioferta?schema=public"
# Ou aponte para Supabase / Railway / Neon.

# ----- Auth (NextAuth) -----
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET="troque-este-valor-em-producao"
NEXTAUTH_URL="http://localhost:3000"

# URL pública do site (usada em Open Graph, sitemap e links de compartilhamento)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="busqueioferta"
NEXT_PUBLIC_SOCIAL_HANDLE="@busqueioferta"

# ----- Mercado Livre -----
ML_CLIENT_ID=
ML_CLIENT_SECRET=
ML_ACCESS_TOKEN=
ML_AFFILIATE_TOOL_ID=          # vai em ?matt_tool=XXXX

# ----- Amazon PA-API -----
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=
AMAZON_HOST=webservices.amazon.com.br

# ----- Redes de afiliados -----
AWIN_API_KEY=
AWIN_PUBLISHER_ID=
LOMADEE_SOURCE_ID=

# ----- Storage -----
CLOUDINARY_URL=

# ----- Social -----
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
TIKTOK_ACCESS_TOKEN=
TIKTOK_PRIVACY_LEVEL=SELF_ONLY   # SELF_ONLY até o app ser auditado; depois PUBLIC_TO_EVERYONE
WHATSAPP_API_URL=              # Zapi ou Evolution API
WHATSAPP_API_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# ----- Email -----
RESEND_API_KEY=
ALERT_FROM_EMAIL="ofertas@busqueioferta.com.br"

# ----- Redis (BullMQ) -----
# Deixe vazio para rodar só o site (sem automação). Descomente para os workers:
# REDIS_URL="redis://localhost:6379"

# ----- Analytics -----
NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# ----- Admin seed (usuário criado pelo seed) -----
SEED_ADMIN_EMAIL="admin@busqueioferta.com.br"
SEED_ADMIN_PASSWORD="admin123"
